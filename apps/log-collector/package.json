{
  "name": "@akashnetwork/log-collector",
  "version": "1.0.0",
  "description": "A log collector worker to forward logs from provider to logging services for certain deployments ",
  "keywords": [
    "logs",
    "collector",
    "forwarding",
    "akash",
    "provider"
  ],
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "NODE_ENV=production tsup && tsc -p tsconfig.build.json",
    "build:container": "cd ../.. && docker build -f apps/log-collector/Dockerfile -t log-collector:local .",
    "dev": "tsup --watch",
    "format": "prettier --write ./*.{js,json} **/*.{ts,js,json}",
    "lint": "eslint .",
    "migration:gen": "drizzle-kit generate",
    "prod": "node dist/index.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@akashnetwork/env-loader": "*",
    "@akashnetwork/http-sdk": "*",
    "@akashnetwork/logging": "*",
    "@kubernetes/client-node": "^1.3.0",
    "lodash": "^4.17.21",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "ws": "^8.18.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@akashnetwork/dev-config": "*",
    "@akashnetwork/releaser": "*",
    "@faker-js/faker": "^8.4.1",
    "@swc/core": "^1.11.10",
    "@types/node": "^22.13.11",
    "@vitest/coverage-v8": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.0",
    "vitest-mock-extended": "^1.3.1"
  }
}
