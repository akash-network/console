{
  "name": "@akashnetwork/openapi-sdk",
  "version": "1.0.0",
  "description": "Typed OpenAPI client runtime (Proxy-based createApi).",
  "license": "Apache-2.0",
  "author": "Akash Network",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "main": "src/index.ts",
  "scripts": {
    "format": "prettier --write ./*.{ts,json} **/*.{ts,json}",
    "lint": "eslint .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "validate:types": "tsc -p tsconfig.build.json --noEmit && echo"
  },
  "devDependencies": {
    "@akashnetwork/dev-config": "*",
    "vitest": "^4.0.0"
  }
}
